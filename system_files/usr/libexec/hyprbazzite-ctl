#!/usr/bin/env bash
set -euo pipefail

# ===============================================================================
# Hyprbazzite Control Center (hyprbazzite-ctl)
# A unified manager for TDP, OSK, Power, and System settings.
# ==============================================================================

# --- Shared Helpers ---
log() { echo "[hyprbazzite-ctl] $*" >&2; }

notify() {
    local title="$1"
    local msg="$2"
    local urgency="${3:-normal}"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -u "$urgency" "$title" "$msg"
    fi
}

json_escape() {
    local s="$1"
    s=${s//\\/\\\\}
    s=${s//"/\\"}
    s=${s//$'\n'/\\n}
    printf '%s' "$s"
}

# --- TDP Module ---
tdp_get_backend() {
    if command -v ryzenadj >/dev/null 2>&1; then echo "ryzenadj"; return 0; fi
    if command -v amdctl >/dev/null 2>&1; then echo "amdctl"; return 0; fi
    if [ -d /sys/class/hwmon ]; then echo "sysfs"; return 0; fi
    return 1
}

tdp_get_current() {
    local backend
    backend=$(tdp_get_backend || echo "unknown")
    case "$backend" in
        ryzenadj) ryzenadj --info | grep -E 'TDP|CPU Name' ;;
        amdctl) amdctl info | grep -i 'power limit\|cpu model' ;;
        sysfs) 
            local cap_file
            cap_file=$(find /sys/class/hwmon/hwmon* -name "power1_cap" | head -n1)
            if [ -n "$cap_file" ]; then
                echo "Current TDP: $(( $(cat "$cap_file") / 1000000 ))W"
            else
                echo "TDP not found in sysfs"
            fi
            ;;
        *) echo "TDP control unsupported" ;;
    esac
}

tdp_set() {
    local watts="$1"
    local backend
    backend=$(tdp_get_backend || { notify "Error" "TDP backend not found"; exit 1; })
    
    case "$backend" in
        ryzenadj) sudo ryzenadj --stapm-limit=$((watts*1000)) --fast-limit=$((watts*1000)) --slow-limit=$((watts*1000)) ;;
        amdctl) sudo amdctl set power-limit "$watts" ;;
        sysfs) 
            local cap_file
            cap_file=$(find /sys/class/hwmon/hwmon* -name "power1_cap" | head -n1)
            echo $((watts * 1000000)) | sudo tee "$cap_file" >/dev/null
            ;;
    esac
    notify "TDP Updated" "Set to ${watts}W via $backend"
}

tdp_menu() {
    local current
    current=$(tdp_get_current | grep -o '[0-9]\+' | head -n1 || echo "unknown")
    local options="10W\n15W\n25W\n35W\n45W"
    local choice
    choice=$(echo -e "$options" | wofi --dmenu --width 300 --height 400 --prompt "Set TDP (Current: ${current}W)")
    if [ -n "$choice" ]; then
        local watts=$(echo "$choice" | grep -o '[0-9]\+')
        tdp_set "$watts"
    fi
}

# --- OSK Module ---
osk_toggle() {
    local bin="wvkbd"
    if command -v wvkbd-mobintl >/dev/null 2>&1; then bin="wvkbd-mobintl"; fi
    if pgrep -x "$bin" >/dev/null 2>&1; then
        pkill -x "$bin"
        notify "Keyboard" "OSK hidden"
    else
        "$bin" --hidden -H 420 -L 320 >/dev/null 2>&1 &
        sleep 0.2
        pkill -USR2 -x "$bin" >/dev/null 2>&1 || true
        notify "Keyboard" "OSK shown"
    fi
}

# --- Power Module ---
power_menu() {
    local options="󰐥 Shutdown\n󰑐 Reboot\n󰒲 Suspend\n󰓅 Hybrid-Sleep\n󰌾 Lock\n󰗼 Logout"
    local choice
    choice=$(echo -e "$options" | wofi --dmenu --width 300 --height 400 --prompt "System Power")
    case "$choice" in
        *"Shutdown"*) power_action shutdown ;;
        *"Reboot"*) power_action reboot ;;
        *"Suspend"*) power_action suspend ;;
        *"Hybrid-Sleep"*) power_action hybrid-sleep ;;
        *"Lock"*) power_action lock ;;
        *"Logout"*) power_action logout ;;
        *) return 0 ;;
    esac
}

power_action() {
    local action="$1"
    case "$action" in
        shutdown) systemctl poweroff ;;
        reboot) systemctl reboot ;;
        suspend) systemctl suspend ;;
        hybrid-sleep) systemctl suspend-then-hibernate ;;
        lock) hyprlock ;;
        logout) hyprctl dispatch exit ;;
        *) echo "Unknown power action: $action"; exit 1 ;;
    esac
}

power_profile_cycle() {
    local current
    current=$(busctl --system get-property net.hadess.PowerProfiles /net/hadess/PowerProfiles net.hadess.PowerProfiles ActiveProfile 2>/dev/null | awk -F'"' '{print $2}')
    local next
    case "$current" in
        power-saver) next='balanced' ;;
        balanced) next='performance' ;;
        performance) next='power-saver' ;;
        *) next='balanced' ;;
    esac
    if busctl --system set-property net.hadess.PowerProfiles /net/hadess/PowerProfiles net.hadess.PowerProfiles ActiveProfile s "$next" >/dev/null 2>&1; then
        notify "Power Profile" "Switched to ${next}"
    elif command -v tuned-adm >/dev/null 2>&1 && sudo -n tuned-adm profile balanced >/dev/null 2>&1; then
        notify "Power Profile" "Switched to balanced via tuned-adm"
    else
        notify "Error" "Could not switch power profile"
        exit 1
    fi
}

# --- Automation Module ---
automation_dnd() {
    if [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
        echo "Hyprland instance signature not found." >&2
        exit 1
    fi
    socat -U - UNIX-CONNECT:/tmp/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock | while read -r line; do
        case "$line" in
            fullscreen\>\>1) swaync-client --dnd-on ;;
            fullscreen\>\>0) swaync-client --dnd-off ;;
        esac
    done
}

automation_osk() {
    local conf="/etc/hypr/wvkbd.conf"
    [ -f "$conf" ] && . "$conf"
    local layout="${WVKBD_LAYOUT:-mobintl}"
    local font="${WVKBD_FONT:-JetBrains Mono 20}"
    local bg="${WVKBD_BG:-282a36}"
    local fg="${WVKBD_FG:-44475a}"
    local fg_sp="${WVKBD_FG_SP:-bd93f9}"
    local press="${WVKBD_PRESS:-6272a4}"
    local press_sp="${WVKBD_PRESS_SP:-ff79c6}"
    local text="${WVKBD_TEXT:-f8f8f2}"
    local text_sp="${WVKBD_TEXT_SP:-f8f8f2}"
    local alpha="${WVKBD_ALPHA:-230}"
    local height="${WVKBD_HEIGHT:-420}"
    local height_land="${WVKBD_HEIGHT_LANDSCAPE:-320}"
    local layers="${WVKBD_LAYERS:-fullwide,special,emoji,nav}"
    local land_layers="${WVKBD_LANDSCAPE_LAYERS:-landscape,landscapespecial,emoji,nav}"
    local anchor="${WVKBD_ANCHOR:-bottom}"
    local state_file="${XDG_RUNTIME_DIR:-/tmp}/wvkbd-anchor"
    [ -f "$state_file" ] && anchor=$(cat "$state_file" 2>/dev/null || echo "$anchor")
    local bin=""
    command -v wvkbd-mobintl >/dev/null 2>&1 && bin="wvkbd-mobintl" || (command -v wvkbd >/dev/null 2>&1 && bin="wvkbd") || exit 0
    sync_state() {
        if compgen -G "/dev/input/by-id/*-event-kbd" >/dev/null; then
            pkill -x "$bin" >/dev/null 2>&1 || true
        else
            if ! pgrep -x "$bin" >/dev/null 2>&1; then
                "$bin" --hidden -H "$height" -L "$height_land" -l "$layers" --landscape-layers "$land_layers" --fn "$font" --alpha "$alpha" --bg "$bg" --fg "$fg" --fg-sp "$fg_sp" --press "$press" --press-sp "$press_sp" --text "$text" --text-sp "$text_sp" >/dev/null 2>&1 &
            fi
        fi
    }
    sync_state
    hyprctl keyword windowrule "float on, match:class ^(wvkbd|wvkbd-.*)$" >/dev/null 2>&1 || true
    if [ "$anchor" = "top" ]; then
        hyprctl keyword windowrule "move 0 0, match:class ^(wvkbd|wvkbd-.*)$" >/dev/null 2>&1 || true
    else
        hyprctl keyword windowrule "move 0 50%, match:class ^(wvkbd|wvkbd-.*)$" >/dev/null 2>&1 || true
    fi
    udevadm monitor --udev --subsystem-match=input --property | while read -r line; do
        [[ "$line" =~ ACTION=(add|remove|change) ]] && sync_state
    done
}

automation_temp() {
    local best_temp_mc="" best_source="" best_score=-1
    score_source() {
        local src_lc=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
        if [[ "$src_lc" =~ (tctl|cpu|package|x86_pkg_temp|coretemp|k10temp|zenpower|soc_thermal) ]]; then echo 300
        elif [[ "$src_lc" =~ acpitz ]]; then echo 180
        elif [[ "$src_lc" =~ (junction|edge|amdgpu|gpu) ]]; then echo 120
        elif [[ "$src_lc" =~ (nvme|ssd) ]]; then echo 90
        else echo 60; fi
    }
    for zone in /sys/class/thermal/thermal_zone*; do
        [ -r "$zone/temp" ] || continue
        local temp_mc=$(cat "$zone/temp" 2>/dev/null || true)
        local type=$(cat "$zone/type" 2>/dev/null || echo "unknown")
        local score=$(score_source "$type")
        if (( score > best_score )); then best_score=$score; best_temp_mc=$temp_mc; best_source="thermal:${type}"; fi
    done
    for hw in /sys/class/hwmon/hwmon*; do
        [ -d "$hw" ] || continue
        local name=$(cat "$hw/name" 2>/dev/null || echo "unknown")
        for input in "$hw"/temp*_input; do
            [ -r "$input" ] || continue
            local temp_mc=$(cat "$input" 2>/dev/null || true)
            local label=$(cat "${input%_input}_label" 2>/dev/null || echo "temp")
            local score=$(score_source "$name")
            if (( score > best_score )); then best_score=$score; best_temp_mc=$temp_mc; best_source="${name}:${label}"; fi
        done
    done
    if [[ -z "$best_temp_mc" ]]; then
        text="N/A 󰔏"; tooltip="Unavailable"; class="missing"
    else
        local temp_c=$((best_temp_mc / 1000))
        local icon="󰈸"; class="cool"
        (( temp_c >= 70 )) && { icon="󰔄"; class="warm"; }
        (( temp_c >= 85 )) && { icon="󰸁"; class="hot"; }
        text="${temp_c}°C ${icon}"; tooltip="Sensor: $best_source"
    fi
    printf '{"text":"%s","tooltip":"%s","class":"%s"}\n' "$(json_escape "$text")" "$(json_escape "$tooltip")" "$class"
}

# --- Screenshot Module ---
screenshot_take() {
    local mode="${1:-full}"
    local file="$HOME/Pictures/Screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png"
    mkdir -p "$HOME/Pictures/Screenshots"
    if [ "$mode" == "area" ]; then
        grim -g "$(slurp)" "$file"
    else
        grim "$file"
    fi
    if [ -f "$file" ]; then
        wl-copy < "$file"
        notify "Screenshot Taken" "Saved to clipboard."
    fi
}

# --- Lid Module ---
lid_handle() {
    local action="$1"
    local internal_output
    internal_output=$(hyprctl -j monitors 2>/dev/null | jq -r '.[] | select(.name | test("^(eDP|LVDS)")) | .name' | head -n1)
    local external_count
    external_count=$(hyprctl -j monitors 2>/dev/null | jq '[.[] | select(.name | test("^(eDP|LVDS)") | not)] | length')
    case "$action" in
        close)
            if [[ -n "$internal_output" && "$external_count" -gt 0 ]]; then
                hyprctl keyword monitor "$internal_output,disable"
            else
                systemctl hybrid-sleep
            fi
            ;;
        open)
            if [[ -n "$internal_output" ]]; then
                hyprctl reload
            fi
            ;;
        *) echo "Usage: hyprbazzite-ctl lid {close|open}"; exit 1 ;;
    esac
}

# --- Main Entry Point ---
main() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: hyprbazzite-ctl [module] [action] [args...]"
        echo "Modules:"
        echo "  automation [dnd|osk|temp]"
        echo "  tdp [get|set <watts>|profile]"
        echo "  osk toggle"
        echo "  power [profile|menu|shutdown|reboot|suspend|hybrid-sleep|lock|logout]"
        echo "  screenshot [full|area]"
        echo "  lid [close|open]"
        exit 0
    fi

    local module="$1"
    shift

    case "$module" in
        automation)
            case "${1:-}" in
                dnd) automation_dnd ;;
                osk) automation_osk ;;
                temp) automation_temp ;;
                *) echo "Unknown automation action"; exit 1 ;;
            esac
            ;;
        tdp)
            case "${1:-}" in
                get) tdp_get_current ;;
                set) tdp_set "${2:-}" ;;
                profile) tdp_menu ;;
                *) echo "Unknown TDP action"; exit 1 ;;
            esac
            ;;
        osk)
            case "${1:-}" in
                toggle) osk_toggle ;;
                *) echo "Unknown OSK action"; exit 1 ;;
            esac
            ;;
        power)
            case "${1:-}" in
                profile) power_profile_cycle ;;
                menu) power_menu ;;
                *) power_action "${1:-}" ;;
            esac
            ;;
        screenshot)
            screenshot_take "${1:-full}"
            ;;
        lid)
            lid_handle "${1:-}"
            ;;
        *)
            echo "Unknown module: $module"
            exit 1
            ;;
    esac
}

main "$@"
